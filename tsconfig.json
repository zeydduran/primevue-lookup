{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "noEmit": true,
        "jsx": "preserve",
        "lib": ["ES2022", "DOM"]
    },
    "include": ["src/**/*.ts", "src/**/*.vue"]
}
